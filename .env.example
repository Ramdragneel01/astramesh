# AstraMesh environment configuration
# Copy to .env for local customization.

# Build and security policy
VITE_BASE_PATH=/
VITE_ALLOWED_IFRAME_ORIGINS=http://localhost:4300,http://localhost:5401,http://localhost:5402,http://localhost:5403,http://localhost:5404,http://localhost:5405,http://localhost:5406,http://localhost:5407,http://localhost:5408,http://localhost:5409,http://localhost:5410,http://localhost:6006,https://ramdragneel01.github.io,https://github.com
VITE_DEFAULT_USER_ROLE=admin
VITE_CONTROL_PLANE_URL=
VITE_CONTROL_PLANE_PROXY_TARGET=http://localhost:4310

# Control-plane backend
ASTRA_CONTROL_PLANE_PORT=4310
ASTRA_ALLOWED_ORIGINS=http://localhost:4300
ASTRA_ALLOWED_PROBE_ORIGINS=https://ramdragneel01.github.io,https://github.com
ASTRA_PROBE_TIMEOUT_MS=3500
ASTRA_REQUESTS_PER_MINUTE=240
ASTRA_SEED_DEFAULTS=true

# Integrated module URLs
VITE_DRIFT_WATCH_URL=http://localhost:5401
VITE_LLM_JUDGE_URL=http://localhost:5402
VITE_RAGBENCH_URL=http://localhost:5403
VITE_PROMPT_OPS_URL=http://localhost:5404
VITE_NEURALSCOPE_URL=http://localhost:5405
VITE_CONFIG_FORGE_URL=http://localhost:5406
VITE_INTERVIEW_OS_URL=http://localhost:5407
VITE_MLOPS_SENTINEL_URL=http://localhost:5408
VITE_AGENT_TRACER_URL=http://localhost:5409
VITE_AGENTIC_RESEARCH_ASSISTANT_URL=http://localhost:5410
VITE_AGENTIC_UI_URL=http://localhost:6006
VITE_CONTEXT_WATCHDOG_URL=https://github.com/Ramdragneel01/context-watchdog
